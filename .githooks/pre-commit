#!/usr/bin/env bash
# Fast commit gate: static ledger integrity + byte-verify of exactly what this
# commit changes. The full multi-minute gate (./build.sh with no args) is NOT
# run here — run it at session start and after merges; pre-push re-checks the
# outgoing delta. Never bypass with --no-verify: this hook takes seconds, and
# a bad row committed here becomes every other agent's red build.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

fail() {
    echo "PRE-COMMIT FAILED: $*" >&2
    exit 1
}

staged_sources=()
ledger_changed=0
wide_change=0
while IFS= read -r path; do
    case "$path" in
        src/*.cpp) staged_sources+=("$path") ;;
        reverse/functions.csv|reverse/symbols.csv) ledger_changed=1 ;;
        # A header or shim recompiles many TUs while changing NO ledger rows,
        # so the delta byte-verify below would prove nothing. Any such change
        # forces the full gate — this is exactly how a layout-shim experiment
        # could otherwise land a silent regression.
        *.h|reference/shims/*) wide_change=1 ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMRT)

if [ "${#staged_sources[@]}" -eq 0 ] && [ "$ledger_changed" -eq 0 ] && [ "$wide_change" -eq 0 ]; then
    exit 0
fi

if [ "$wide_change" -ne 0 ]; then
    echo "pre-commit: header/shim change — running FULL gate (delta verify can't see wide effects)" >&2
    BUILD_POOL="${BUILD_POOL:-4}" ./build.sh || fail "full gate after header/shim change (see above)"
fi

# The build verifies file contents on disk; refuse if a file being committed
# also has unstaged edits, or we would be proving the wrong bytes.
dirty=()
for path in "${staged_sources[@]}"; do
    if ! git diff --quiet -- "$path"; then
        dirty+=("$path")
    fi
done
for ledger in reverse/functions.csv reverse/symbols.csv; do
    if ! git diff --cached --quiet -- "$ledger" && ! git diff --quiet -- "$ledger"; then
        dirty+=("$ledger")
    fi
done
if [ "${#dirty[@]}" -ne 0 ]; then
    printf '  unstaged edits in: %s\n' "${dirty[@]}" >&2
    fail "staged verification files also have unstaged edits; build would not verify the staged content"
fi

# 1) Static ledger integrity (<1s): duplicate rows, conflicting or overlapping
#    claims, malformed rows, missing sources. Turns union-merge corruption into
#    an immediate loud failure instead of someone else's red build later.
python3 tools/check_csv.py --staged || fail "ledger integrity (see above)"

# 2) Every function defined in staged sources must be declared in the ledger.
if [ "${#staged_sources[@]}" -ne 0 ]; then
    python3 tools/find_declared_unmatched.py --fail --staged "${staged_sources[@]}" \
        || fail "staged sources define functions the ledger does not declare (see above)"
fi

# 3) Byte-verify the delta: staged sources plus sources of any ledger rows this
#    commit adds or edits. Seconds per file. Row deletions and dedup reorders
#    verify nothing extra — they cannot break byte-truth.
declare -A verify_set=()
for path in "${staged_sources[@]}"; do verify_set["$path"]=1; done
while IFS= read -r path; do
    [ -n "$path" ] && verify_set["$path"]=1
done < <(python3 tools/delta_sources.py --staged)

# Parked reconstruction drafts (whitelisted zero-matched-row sources) have
# nothing to byte-verify; build.py errors on a filter that matches no rows.
if [ "${#verify_set[@]}" -ne 0 ]; then
    while IFS= read -r path; do
        unset "verify_set[$path]"
    done < <(python3 - "${!verify_set[@]}" <<'PY'
import csv, sys
claimed = {r["source"] for r in csv.DictReader(open("reverse/functions.csv"))
           if r.get("status") == "matched"}
for p in sys.argv[1:]:
    if p not in claimed:
        print(p)
PY
    )
fi

if [ "${#verify_set[@]}" -ne 0 ]; then
    BUILD_POOL="${BUILD_POOL:-4}" ./build.sh "${!verify_set[@]}" \
        || fail "byte-verify of changed sources (see above)"
fi

echo "PRE-COMMIT OK (ledger integrity + ${#verify_set[@]} source(s) byte-verified)"
